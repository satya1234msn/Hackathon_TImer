{
  "name": "udbhav-2k26-countdown",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "description": "Global synchronized 24-hour hackathon countdown for UDBHAV 2K26",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "nodemon --watch server.js --ext js,mjs,cjs --ignore timer-state.json --ignore dist/ server.js",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "reset:timer": "node scripts/reset-timer.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.21"
  }
}
